{
	"compilerOptions": {
		"lib": ["DOM", "ES2020"],
		"jsx": "react-jsx",
		"target": "ES2020",
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"useDefineForClassFields": true,
		"allowJs": true,
		"outDir": "lib",

		/* modules */
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": false,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"noUncheckedSideEffectImports": true,

		/* type checking */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src"]
}
